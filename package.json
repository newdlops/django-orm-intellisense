{
  "name": "django-orm-intellisense",
  "displayName": "Django ORM Intellisense",
  "description": "VS Code extension scaffold for Django ORM development assistance.",
  "version": "0.0.1",
  "publisher": "newdlops",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:djangoOrmIntellisense.showStatus",
    "onCommand:djangoOrmIntellisense.restartDaemon"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "djangoOrmIntellisense.showStatus",
        "title": "Django ORM Intellisense: Show Status"
      },
      {
        "command": "djangoOrmIntellisense.restartDaemon",
        "title": "Django ORM Intellisense: Restart Daemon"
      }
    ],
    "configuration": {
      "title": "Django ORM Intellisense",
      "properties": {
        "djangoOrmIntellisense.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start the Python analysis daemon when the extension activates."
        },
        "djangoOrmIntellisense.pythonPath": {
          "type": "string",
          "default": "",
          "description": "Python executable used to launch the Django ORM Intellisense analysis daemon."
        },
        "djangoOrmIntellisense.settingsModule": {
          "type": "string",
          "default": "",
          "description": "Optional DJANGO_SETTINGS_MODULE override passed to the analysis daemon."
        },
        "djangoOrmIntellisense.logLevel": {
          "type": "string",
          "enum": [
            "off",
            "info",
            "debug"
          ],
          "default": "info",
          "description": "Controls how much daemon lifecycle logging is written to the extension output channel."
        }
      }
    }
  },
  "keywords": [
    "django",
    "orm",
    "python",
    "intellisense"
  ],
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.17.30",
    "@types/vscode": "^1.90.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.5.2",
    "typescript": "^5.8.3"
  }
}
